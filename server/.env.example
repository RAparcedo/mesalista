# Copy to .env and fill in from Supabase's "Connect" dialog.
# DATABASE_URL: transaction pooler (port 6543) — used by the app at runtime.
# DIRECT_URL:   session pooler / direct (port 5432) — used by Prisma migrations.

DATABASE_URL=""
DIRECT_URL=""

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""
# Seeded admin credentials (prisma db seed)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
